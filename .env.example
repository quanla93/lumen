# Single source of truth — used by BOTH:
#   • Native dev (`make dev-hub`, `make dev-agent`) via godotenv.
#   • Docker Compose via `env_file: ../../.env` in deploy/docker/docker-compose.yml.
#
# Copy to .env and edit:
#   cp .env.example .env
#
# Container-specific quirks (LUMEN_HUB_URL=http://hub:8090, LUMEN_HUB_DB_PATH=/data/lumen.db)
# are overridden inside docker-compose.yml — you don't need to manage two files.

# ─── Hub ──────────────────────────────────────────────────────────────────────
LUMEN_HUB_ADDR=:8090
LUMEN_HUB_DEV=true
LUMEN_HUB_STREAM_INTERVAL=5s

# Native dev only — Docker uses /data/lumen.db (volume-mounted).
LUMEN_HUB_DB_PATH=./lumen.db

# HMAC secret for session JWTs. Stable so sessions survive restarts.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LUMEN_HUB_SECRET=


# ─── Agent ────────────────────────────────────────────────────────────────────
# Native dev only — Docker uses http://hub:8090 (compose DNS).
LUMEN_HUB_URL=http://localhost:8090

LUMEN_AGENT_INTERVAL=5s

# Friendly host name shown in the dashboard; empty → os.Hostname().
LUMEN_AGENT_HOST=

# Per-host bearer token. Empty = anonymous ingest (still accepted today;
# strict-mode opt-in later). Mint a real one in Settings → Hosts after
# registering the first admin.
LUMEN_AGENT_TOKEN=

# Optional — only needed if you start the `agent2` compose service
# (`docker compose --profile extra up -d agent2`). Mint a separate host
# token in the UI for it.
LUMEN_AGENT_TOKEN_2=
