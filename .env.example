# Single source of truth — used by BOTH:
#   • Native dev (`make dev-hub`, `make dev-agent`) via godotenv.
#   • Docker Compose via `env_file: ../../.env` in deploy/docker/docker-compose.yml.
#
# Copy to .env and edit:
#   cp .env.example .env
#
# Container-specific quirks (LUMEN_HUB_URL=http://hub:8090, LUMEN_HUB_DB_PATH=/data/lumen.db)
# are overridden inside docker-compose.yml — you don't need to manage two files.

# ─── Hub ──────────────────────────────────────────────────────────────────────
LUMEN_HUB_ADDR=:8090
LUMEN_HUB_DEV=true
LUMEN_HUB_STREAM_INTERVAL=5s

# Native dev only — Docker uses /data/lumen.db (volume-mounted).
LUMEN_HUB_DB_PATH=./lumen.db

# HMAC secret for session JWTs. Stable so sessions survive restarts.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LUMEN_HUB_SECRET=

# Retention: prune snapshots older than WINDOW every INTERVAL. Set either
# to "0" to disable the prune loop entirely (e.g. while debugging).
LUMEN_HUB_RETENTION_WINDOW=24h
LUMEN_HUB_RETENTION_INTERVAL=1h

# Runtime policy served to agents. Running agents apply changes after their
# next policy fetch; env only seeds the DB on first hub startup.
LUMEN_HUB_AGENT_INTERVAL=5s

# Coalesced batch flush — every accepted ingest is buffered in memory
# and INSERTed into SQLite together every FLUSH_EVERY (or once
# FLUSH_SIZE rows are pending, whichever first). Cuts WAL fsync
# pressure on HDDs ~100× at fleet scale. Worst-case loss on a hub
# crash is one FLUSH_EVERY of recent rows (the agent's local buffer
# replays them once the hub comes back).
LUMEN_HUB_BATCH_FLUSH_EVERY=60s
LUMEN_HUB_BATCH_FLUSH_SIZE=5000

# Seed admin — runs on every hub startup. If this user already exists in
# the DB, it's left alone (passwords changed via UI survive restarts).
# If absent, the hub creates it with Argon2id-hashed password. Both
# values must be set together; both empty disables the seed.
# CHANGE THE PASSWORD in production.
LUMEN_HUB_ADMIN_USERNAME=admin
LUMEN_HUB_ADMIN_PASSWORD=lumenadmin


# ─── Agent ────────────────────────────────────────────────────────────────────
# Native dev only — Docker uses http://hub:8090 (compose DNS).
LUMEN_HUB_URL=http://localhost:8090

# Bootstrap collection interval. After the agent connects, the hub Runtime
# setting can override this without redeploying the agent.
LUMEN_AGENT_INTERVAL=5s

# Friendly host name shown in the dashboard; empty → os.Hostname().
LUMEN_AGENT_HOST=

# Persistent offline queue. When the hub is unreachable the agent
# appends ingest envelopes here and replays them gradually after
# reconnect. Defaults are sized for 24h of 5s ticks. Compose overrides
# to /data/buffer.db (lumen-agent-data volume); systemd installer
# overrides to /var/lib/lumen-agent/buffer.db.
LUMEN_AGENT_BUFFER_PATH=./lumen-agent-buffer.db
LUMEN_AGENT_BUFFER_MAX_AGE=24h
LUMEN_AGENT_BUFFER_DRAIN=10

# Per-host bearer token. REQUIRED — the hub returns 401 to every ingest
# without it. Sign in at http://localhost:8090, Settings → Hosts →
# Create → copy the one-shot `lum_...` token here.
LUMEN_AGENT_TOKEN=

# Optional — only needed if you start the `agent2` compose service
# (`docker compose --profile extra up -d agent2`). Mint a separate host
# token in the UI for it.
LUMEN_AGENT_TOKEN_2=
