# Lumen — example environment file.
# Copy to .env for local dev:  cp .env.example .env
# .env is gitignored. Both lumen-hub and lumen-agent load it from CWD on startup.

# ─── Hub ──────────────────────────────────────────────────────────────────────
# Address the hub binds to.
LUMEN_HUB_ADDR=:8090

# Enable verbose request logging and slog DEBUG level. Off in prod.
LUMEN_HUB_DEV=true

# WebSocket broadcast cadence on /api/stream (Go duration).
LUMEN_HUB_STREAM_INTERVAL=5s


# ─── Agent ────────────────────────────────────────────────────────────────────
# Hub base URL (no trailing slash).
LUMEN_HUB_URL=http://localhost:8090

# Bearer token sent in Authorization header. Ignored by the hub until Phase 2.
LUMEN_AGENT_TOKEN=devtoken

# Collection interval (Go duration: 5s, 1m, 250ms ...).
LUMEN_AGENT_INTERVAL=5s

# Optional override of the host identifier. Defaults to os.Hostname().
# LUMEN_AGENT_HOST=
