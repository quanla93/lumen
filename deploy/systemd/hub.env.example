# Lumen hub environment.
#
# Installed at /etc/lumen/hub.env by install-hub.sh on first run; preserved
# on upgrade. Edit, then `sudo systemctl restart lumen-hub` to apply.
#
# Mode 0640, root:lumen — readable by the lumen service user, not world.

# ─── Network ──────────────────────────────────────────────────────────────────
LUMEN_HUB_ADDR=:8090
LUMEN_HUB_DEV=false

# How often /api/stream re-broadcasts the live snapshot to WS clients.
LUMEN_HUB_STREAM_INTERVAL=5s


# ─── Storage ──────────────────────────────────────────────────────────────────
# SQLite file. install-hub.sh sets this to /var/lib/lumen/lumen.db and creates
# the directory owned by the lumen user.
LUMEN_HUB_DB_PATH=/var/lib/lumen/lumen.db

# Snapshots older than WINDOW are pruned every INTERVAL. Set either to "0"
# to disable retention.
LUMEN_HUB_RETENTION_WINDOW=24h
LUMEN_HUB_RETENTION_INTERVAL=1h

# Future cold-tier policy. bucket_size is the time span represented by one
# archived data point (5m = average old samples into one point every 5 minutes).
# hot_window is how long full-detail raw rows stay in SQLite (24h = keep every
# agent sample for the last day). archive_window is how long compressed history
# is kept (8760h = one year).
LUMEN_HUB_DOWNSAMPLE_BUCKET_SIZE=5m
LUMEN_HUB_DOWNSAMPLE_HOT_WINDOW=24h
LUMEN_HUB_DOWNSAMPLE_ARCHIVE_WINDOW=8760h

# Batched persistence. Ingest snapshots accumulate in memory and INSERT
# into SQLite in one transaction every FLUSH_EVERY (or once FLUSH_SIZE
# rows are pending). Coalesces fsync pressure on HDD-backed setups.
# Worst-case data loss on hub crash = one FLUSH_EVERY of recent rows
# (the agent's local buffer replays them after reconnect).
LUMEN_HUB_BATCH_FLUSH_EVERY=60s
LUMEN_HUB_BATCH_FLUSH_SIZE=5000


# ─── Security ─────────────────────────────────────────────────────────────────
# HMAC secret for session JWTs. install-hub.sh generates a random 32-byte
# hex value on FIRST install and writes it here. Keep this stable across
# restarts (or sessions die).
LUMEN_HUB_SECRET=

# Seed admin. If the user doesn't exist yet, install creates it with
# Argon2id-hashed password. Existing user is left alone — passwords changed
# via UI survive restart. Both empty disables the seed.
# CHANGE LUMEN_HUB_ADMIN_PASSWORD before exposing the hub on a network.
LUMEN_HUB_ADMIN_USERNAME=admin
LUMEN_HUB_ADMIN_PASSWORD=lumenadmin


# ─── Agent install endpoint (optional) ────────────────────────────────────────
# Path to a directory containing install.sh + lumen-agent-<os>-<arch> binaries
# that the hub will serve at /install.sh and /install/<binary>. Leave empty
# to disable — the hub still runs fine, just without the agent one-liner.
LUMEN_HUB_INSTALL_DIR=
