# Lumen — REST Client requests.
#
# Compatible with VS Code "REST Client" (humao.rest-client),
# JetBrains/IntelliJ HTTP Client, and Visual Studio HTTP Files.
#
# For Postman / Insomnia / Bruno / Hoppscotch: import api/openapi.yaml instead.
# For the WebSocket /api/stream endpoint, see the snippet at the bottom.

@hub = http://localhost:8090
@host = pve-01
# Strict bearer-token auth: ingest now requires a real token. Mint one
# in Settings → Hosts after sign-in, paste it here.
@token = lum_REPLACE_ME
@username = admin
@password = correcthorse

###
# Liveness — should return 200 with {"status":"ok"}.
GET {{hub}}/healthz

###
# Auth — check if first-admin registration is still available.
GET {{hub}}/api/setup-status

###
# Auth — register the first admin (one-shot; subsequent calls 403).
POST {{hub}}/api/register
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
# Auth — log in (sets `lumen_session` HttpOnly cookie).
POST {{hub}}/api/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
# Auth — current session user (401 without cookie).
GET {{hub}}/api/me

###
# Auth — clear the session cookie.
POST {{hub}}/api/logout

###
# Hosts — list (session required).
GET {{hub}}/api/hosts

###
# Hosts — create + mint one-shot bearer token.
POST {{hub}}/api/hosts
Content-Type: application/json

{
  "name": "{{host}}"
}

###
# Hosts — rotate token for host id 1.
POST {{hub}}/api/hosts/1/rotate

###
# Hosts — delete host id 1.
DELETE {{hub}}/api/hosts/1

###
# Hosts — last hour of history for host id 1, server-picked step.
GET {{hub}}/api/hosts/1/metrics

###
# Hosts — explicit range + 30s buckets.
GET {{hub}}/api/hosts/1/metrics?from=2026-05-26T00:00:00Z&to=2026-05-26T06:00:00Z&step=30s

###
# Ingest a full metric envelope. Auth header accepted, not validated yet.
POST {{hub}}/api/ingest
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "host": "{{host}}",
  "ts": "2026-05-25T07:09:53Z",
  "cpu_pct": 12.34,
  "ram_pct": 68.0,
  "swap_pct": 23.6,
  "disk_pct": 73.1,
  "load1": 0.42,
  "load5": 0.31,
  "load15": 0.28
}

###
# Minimal envelope — only host + ts required; metric fields default to 0.
POST {{hub}}/api/ingest
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "host": "{{host}}",
  "ts": "2026-05-25T07:09:53Z",
  "cpu_pct": 12.34
}

###
# Ingest — missing host (expect 400).
POST {{hub}}/api/ingest
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "ts": "2026-05-25T07:09:53Z",
  "cpu_pct": 12.34
}

###
# Ingest — cpu_pct out of range (expect 400).
POST {{hub}}/api/ingest
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "host": "{{host}}",
  "ts": "2026-05-25T07:09:53Z",
  "cpu_pct": 150
}

###
# WebSocket /api/stream is not driveable from this file. Use either:
#
# 1) Node 22+ one-liner:
#    node -e "const ws=new WebSocket('ws://localhost:8090/api/stream'); \
#             ws.onmessage=e=>console.log(e.data); \
#             setTimeout(()=>{ws.close();process.exit(0)}, 15000)"
#
# 2) websocat (https://github.com/vi/websocat):
#    websocat ws://localhost:8090/api/stream
#
# 3) wscat (npm i -g wscat):
#    wscat -c ws://localhost:8090/api/stream
#
# 4) Browser DevTools console:
#    const ws=new WebSocket('ws://localhost:8090/api/stream');
#    ws.onmessage=e=>console.log(JSON.parse(e.data));
